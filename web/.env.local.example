# Copy this file to .env.local and fill in the values.

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Authentik SSO
AUTHENTIK_URL=https://authentik.yourdomain.com
AUTHENTIK_FLOW_SLUG=default-authentication-flow

# Laravel API — server-side only (never exposed to browser)
API_URL=http://localhost:8000
API_SYNC_SECRET=          # must match AUTH_SYNC_SECRET in api/.env

# Laravel API — browser-accessible (for CSP and client-side calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Admin-only mode: comma-separated emails allowed to sign in via SSO during development.
# Leave empty to allow all authenticated Authentik users.
ADMIN_EMAILS=

# Break-glass: enable local superadmin login when Authentik is unavailable.
# Must also set ALLOW_LOCAL_AUTH=true and SUPER_ADMIN_PASSWORD in api/.env.
ALLOW_LOCAL_AUTH=false
