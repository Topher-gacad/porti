# Copy this file to .env.local and fill in the values.

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Authentik SSO
AUTHENTIK_URL=https://authentik.yourdomain.com
AUTHENTIK_FLOW_SLUG=default-authentication-flow

# Laravel API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Admin-only mode: comma-separated emails allowed to sign in during development.
# Leave empty to allow all authenticated Authentik users.
ADMIN_EMAILS=
