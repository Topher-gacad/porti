APP_NAME="IT Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local: sqlite — Production: switch to pgsql
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=portal_db
# DB_USERNAME=portal_user
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Local: sync — Production: switch to redis
QUEUE_CONNECTION=sync

# Local: file — Production: switch to redis
CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourcompany.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AUTHENTIK SSO ---
AUTHENTIK_BASE_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_REDIRECT_URI=http://localhost:8000/api/auth/callback

# --- FRONTEND ---
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- ACCESS CONTROL ---
# true = only super-admin / developer roles can access the API (development phase default)
APP_ADMIN_ONLY=true

# Shared secret between Next.js and Laravel for the user sync endpoint
AUTH_SYNC_SECRET=

# Email that gets auto-assigned super-admin role on their first login
SUPER_ADMIN_EMAIL=

# Break-glass local account (bypasses Authentik).
# Set to true only when Authentik is unavailable. Keep false in normal operation.
ALLOW_LOCAL_AUTH=false
SUPER_ADMIN_PASSWORD=

# --- DEV USER (created by `php artisan db:seed`, non-production only) ---
DEV_USER_EMAIL=
DEV_USER_PASSWORD=
